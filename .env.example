# Copy this file to .env.local for local trend/monitor runs.
# Agent Workbench itself does not need a token.
# Never commit .env.local or paste tokens into issues, logs, or chat.
GITHUB_TOKEN=
GH_TOKEN=

# Optional: default target repository for monitor/orchestrate.
GITHUB_OWNER=OWNER
GITHUB_REPO=agent-workbench
TARGET_REPO=OWNER/agent-workbench

# Optional: keep the GitHub API version explicit for reproducible local runs.
GITHUB_API_VERSION=2026-03-10
